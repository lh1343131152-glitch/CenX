<?xml version="1.0" encoding="utf-8"?>
<!-- 闪光灯按钮背景：圆形半透明 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="false" android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#33FFFFFF" />
            <stroke android:width="1.5dp" android:color="#88FFFFFF" />
        </shape>
    </item>
    <item android:state_selected="false">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
            <stroke android:width="1dp" android:color="#55FFFFFF" />
        </shape>
    </item>
    <item android:state_selected="true" android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#40FFD700" />
            <stroke android:width="1.5dp" android:color="#CCFFD700" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#30FFD700" />
            <stroke android:width="1.5dp" android:color="#AAFFD700" />
        </shape>
    </item>
</selector>
