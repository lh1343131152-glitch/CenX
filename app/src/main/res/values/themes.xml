<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- HyperOS / 澎湃 OS 全局主题 -->
    <style name="Theme.BrowserApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="colorControlHighlight">@color/surface_pressed</item>

        <item name="colorSurface">@color/background</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/divider</item>
        <item name="colorSurfaceContainer">@color/dialog_background</item>
        <item name="colorSurfaceContainerHigh">@color/card_background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <!-- 关闭动态取色，保持全局澎湃 OS 固定视觉 -->
        <!-- dynamicColorThemeOverlay intentionally removed -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.CenX.MaterialAlertDialog</item>

        <!-- 全局控件 -->
        <item name="cardViewStyle">@style/CardView.HyperOS</item>
        <item name="materialSwitchStyle">@style/Widget.CenX.MaterialSwitch</item>
    </style>

    <!-- HyperOS 风格卡片 -->
    <style name="CardView.HyperOS">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- Toolbar 配色 -->
    <style name="ToolbarStyleColorOS">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- 带填充色的Toolbar（用于部分Activity顶部有颜色） -->
    <style name="ToolbarStyleColorOS.Primary">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="ThemeOverlay.CenX.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">?attr/colorSurfaceContainer</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CenX.Dialog</item>
    </style>

    <style name="ThemeOverlay.CenX.DynamicColorDisabled" parent="">
        <item name="colorOutline">#FFA0642F</item>
    </style>

    <style name="ThemeOverlay.CenX.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.CenX.BottomSheet</item>
    </style>

    <style name="Widget.CenX.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">?attr/colorSurfaceContainer</item>
        <item name="shapeAppearance">@style/ShapeAppearance.CenX.BottomSheet</item>
    </style>

    <style name="Widget.CenX.MaterialSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="useMaterialThemeColors">true</item>
    </style>

    <style name="ShapeAppearance.CenX.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>

    <style name="ShapeAppearance.CenX.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- 小说阅读器专属主题 -->
    <style name="Theme.BrowserApp.ReaderMode" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#F6EFD9</item>
        <item name="colorPrimaryDark">#F6EFD9</item>
        <item name="colorAccent">#5C4632</item>
        <item name="colorControlNormal">#5C4632</item>
        <item name="colorControlHighlight">#225C4632</item>
        <item name="android:windowBackground">#F6EFD9</item>
        <item name="android:statusBarColor">#F6EFD9</item>
        <item name="android:navigationBarColor">#F6EFD9</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>