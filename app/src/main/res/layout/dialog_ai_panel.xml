<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainer"
    android:paddingTop="8dp"
    android:paddingBottom="12dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bottom_sheet_handle"
        android:alpha="0.34" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="CenX AI"
        android:textColor="?attr/colorOnSurface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="对当前网页进行总结、解释或继续 AI 对话"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:alignmentMode="alignMargins"
        android:columnCount="3"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:useDefaultMargins="true">

        <LinearLayout
            android:id="@+id/ai_action_chat"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bottom_sheet_action_item_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/home_surface_primary_round"
                android:gravity="center"
                android:text="聊"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="AI聊天"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ai_action_summary"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bottom_sheet_action_item_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/home_surface_primary_round"
                android:gravity="center"
                android:text="摘"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="总结网页"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ai_action_explain"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bottom_sheet_action_item_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/home_surface_primary_round"
                android:gravity="center"
                android:text="解"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="解释网页"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ai_action_reader"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bottom_sheet_action_item_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/home_surface_primary_round"
                android:gravity="center"
                android:text="阅"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="小说模式"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ai_action_settings"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bottom_sheet_action_item_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/home_surface_primary_round"
                android:gravity="center"
                android:text="设"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="AI设置"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>
    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ai_panel_close"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:text="关闭"
        android:textColor="?attr/colorPrimary" />
</LinearLayout>