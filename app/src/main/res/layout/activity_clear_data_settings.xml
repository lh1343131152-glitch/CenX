<?xml version="1.0" encoding="utf-8"?>
<com.centigrade.ui.widget.HyperRootLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_settings_subpage"
    android:background="?attr/colorSurfaceContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/layout_appbar_toolbar" />

    <com.centigrade.ui.widget.HyperScrollView
        android:id="@+id/settings_subpage_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:hyperClipToPadding="false">

        <com.centigrade.ui.widget.HyperCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <com.centigrade.ui.widget.HyperTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="清理浏览数据"
                    app:hyperTextStyle="section" />

                <com.centigrade.ui.widget.HyperButton
                    android:id="@+id/btn_clear_cache"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:text="清除缓存"
                    app:hyperButtonStyle="danger" />

                <com.centigrade.ui.widget.HyperButton
                    android:id="@+id/btn_clear_history"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="清除历史记录"
                    app:hyperButtonStyle="danger" />

                <com.centigrade.ui.widget.HyperButton
                    android:id="@+id/btn_clear_cookies"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="清除Cookie"
                    app:hyperButtonStyle="danger" />
            </LinearLayout>
        </com.centigrade.ui.widget.HyperCardView>
    </com.centigrade.ui.widget.HyperScrollView>
</com.centigrade.ui.widget.HyperRootLayout>