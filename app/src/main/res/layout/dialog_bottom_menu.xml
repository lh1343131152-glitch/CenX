<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainer"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:alpha="0.5"
        android:background="?attr/colorOutline" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:text="更多"
        android:textColor="?attr/colorOnSurface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:useDefaultMargins="true">

        <LinearLayout
            android:id="@+id/menu_bookmarks"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmarks_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_bookmarks"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_history"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_history"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_download"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_download_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_download"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_share_page"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_share_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_share_page"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_source"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_code_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_source"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_resource_sniffer"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_travel_explore_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="资源嗅探"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_scan"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_qr_code_scanner_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="扫一扫"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_fullscreen"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_fullscreen_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="全屏模式"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_ai"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_auto_awesome_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_ai"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_toolbox"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_inventory_2_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_toolbox"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_settings"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_settings"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_incognito"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:id="@+id/icon_incognito"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_visibility_off_24"
                android:tint="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/text_incognito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_incognito"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>
    </GridLayout>

    <com.centigrade.ui.widget.HyperButton
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="取消"
        app:hyperButtonStyle="secondary" />

</LinearLayout>