<?xml version="1.0" encoding="utf-8"?>
<com.centigrade.ui.widget.HyperRootLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_settings_subpage"
    android:background="?attr/colorSurfaceContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/layout_appbar_toolbar" />

    <com.centigrade.ui.widget.HyperScrollView
        android:id="@+id/settings_subpage_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:hyperClipToPadding="false">

        <com.centigrade.ui.widget.HyperCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <com.centigrade.ui.widget.HyperTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/setting_adblock"
                        app:hyperTextStyle="body" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_adblock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <com.centigrade.ui.widget.HyperTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/setting_incognito"
                        app:hyperTextStyle="body" />

                    

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_incognito"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <com.centigrade.ui.widget.HyperTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/setting_resource_sniff"
                        app:hyperTextStyle="body" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_resource_sniff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <com.centigrade.ui.widget.HyperTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="DoH/Hosts接管资源加载"
                        app:hyperTextStyle="body" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_doh_webview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/switch_dynamic_color"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <com.centigrade.ui.widget.HyperTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="动态取色（Android 12+）"
                            app:hyperTextStyle="body" />

                        <com.centigrade.ui.widget.HyperTextView
                            android:id="@+id/tv_dynamic_color_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="开启后跟随系统壁纸配色，关闭后使用 CenX 固定配色"
                            app:hyperTextStyle="caption" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_dynamic_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <com.centigrade.ui.widget.HyperTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="渲染模式"
                    app:hyperTextStyle="section" />

                <RadioGroup
                    android:id="@+id/group_render_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_render_standard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="标准" />

                    <RadioButton
                        android:id="@+id/radio_render_compat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="兼容" />

                    <RadioButton
                        android:id="@+id/radio_render_enhanced"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="增强" />
                </RadioGroup>

                <com.centigrade.ui.widget.HyperTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="缓存策略"
                    app:hyperTextStyle="section" />

                <RadioGroup
                    android:id="@+id/group_cache_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_cache_default"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="默认" />

                    <RadioButton
                        android:id="@+id/radio_cache_else_network"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="缓存优先" />

                    <RadioButton
                        android:id="@+id/radio_cache_no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="不使用缓存" />

                    <RadioButton
                        android:id="@+id/radio_cache_only"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="仅离线缓存" />
                </RadioGroup>

                <com.centigrade.ui.widget.HyperTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="加载模式"
                    app:hyperTextStyle="section" />

                <RadioGroup
                    android:id="@+id/group_load_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_load_standard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="标准" />

                    <RadioButton
                        android:id="@+id/radio_load_fast"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="极速" />

                    <RadioButton
                        android:id="@+id/radio_load_data_save"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="省流" />
                </RadioGroup>
            </LinearLayout>
        </com.centigrade.ui.widget.HyperCardView>
    </com.centigrade.ui.widget.HyperScrollView>
</com.centigrade.ui.widget.HyperRootLayout>