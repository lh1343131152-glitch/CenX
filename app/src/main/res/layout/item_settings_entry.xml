<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingTop="16dp"
    android:paddingEnd="18dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.centigrade.ui.widget.HyperTextView
            android:id="@+id/tv_entry_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="标题"
            app:hyperTextStyle="body" />

        <com.centigrade.ui.widget.HyperTextView
            android:id="@+id/tv_entry_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="说明"
            app:hyperTextStyle="caption" />
    </LinearLayout>

    <com.centigrade.ui.widget.HyperTextView
        android:id="@+id/tv_entry_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxWidth="140dp"
        android:singleLine="true"
        android:text=""
        
        app:hyperTextStyle="value" />

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="10dp"
        android:src="@drawable/forward"
        android:tint="?attr/colorOutline" />
</LinearLayout>