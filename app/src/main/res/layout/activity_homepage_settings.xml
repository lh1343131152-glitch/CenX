<?xml version="1.0" encoding="utf-8"?>
<com.centigrade.ui.widget.HyperRootLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_settings_subpage"
    android:background="?attr/colorSurfaceContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/layout_appbar_toolbar" />

    <com.centigrade.ui.widget.HyperScrollView
        android:id="@+id/settings_subpage_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:hyperClipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.centigrade.ui.widget.HyperCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <RadioGroup
                        android:id="@+id/homepage_type_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/homepage_type_default"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:text="@string/homepage_default_page"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/homepage_type_custom"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:text="@string/homepage_custom_url"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />
                    </RadioGroup>

                    <EditText
                        android:id="@+id/homepage_edit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/url_bg"
                        android:gravity="center_vertical"
                        android:hint="@string/homepage_default"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />

                    <com.centigrade.ui.widget.HyperButton
                        android:id="@+id/btn_save_homepage"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="保存主页"
                        app:hyperButtonStyle="primary" />

                    <com.centigrade.ui.widget.HyperButton
                        android:id="@+id/btn_manage_quick_links"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/homepage_quick_links"
                        app:hyperButtonStyle="secondary" />
                </LinearLayout>
            </com.centigrade.ui.widget.HyperCardView>

            <com.centigrade.ui.widget.HyperCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <com.centigrade.ui.widget.HyperTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="主页背景图"
                        app:hyperTextStyle="body" />

                    <EditText
                        android:id="@+id/edit_home_background"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/url_bg"
                        android:gravity="center_vertical"
                        android:hint="选择主页背景图路径"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />

                    <com.centigrade.ui.widget.HyperButton
                        android:id="@+id/btn_pick_home_background"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="选择背景图"
                        app:hyperButtonStyle="secondary" />

                    <com.centigrade.ui.widget.HyperButton
                        android:id="@+id/btn_save_home_background"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="保存背景图"
                        app:hyperButtonStyle="primary" />
                </LinearLayout>
            </com.centigrade.ui.widget.HyperCardView>

        </LinearLayout>
    </com.centigrade.ui.widget.HyperScrollView>
</com.centigrade.ui.widget.HyperRootLayout>