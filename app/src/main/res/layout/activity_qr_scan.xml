<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 扫描区域遮罩 -->
    <View
        android:id="@+id/scan_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- 扫描线 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <ImageView
            android:id="@+id/scan_line"
            android:layout_width="260dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginTop="-40dp"
            android:src="@drawable/ic_scan_line"
            android:scaleType="fitXY"
            android:translationY="-130dp" />
    </FrameLayout>

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tv_scan_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="320dp"
        android:text="将二维码/条码放入框内即可识别"
        android:textColor="#BBFFFFFF"
        android:textSize="13sp"
        android:alpha="0.9" />

    <!-- 标题栏 - 嵌入状态栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#99000000"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_scan_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="center"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="扫一扫"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_scan_album"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="相册"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:background="@drawable/bg_scan_album_btn"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 底部闪光灯按钮 -->
    <ImageButton
        android:id="@+id/btn_flashlight"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="60dp"
        android:src="@drawable/ic_flashlight"
        android:background="@drawable/bg_scan_flash_btn"
        android:scaleType="center"
        android:contentDescription="闪光灯"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</FrameLayout>
